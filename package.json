{
  "name": "@owdproject/core",
  "version": "4.0.0",
  "description": "Open Web Desktop core — wrapper for nuxt-desktop",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt-desktop",
    "desktop",
    "web-desktop",
    "vue",
    "owd",
    "open-web-desktop"
  ],
  "homepage": "https://github.com/owdproject/core#readme",
  "bugs": {
    "url": "https://github.com/owdproject/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owdproject/core.git"
  },
  "license": "MIT",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "nuxt-desktop",
      "default": "nuxt-desktop"
    },
    "./module": {
      "import": "nuxt-desktop/module",
      "default": "nuxt-desktop/module"
    },
    "./nuxt": {
      "import": "nuxt-desktop/module",
      "default": "nuxt-desktop/module"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "echo 'Development happens in nuxt-desktop'"
  },
  "dependencies": {
    "nuxt-desktop": "workspace:*"
  }
}