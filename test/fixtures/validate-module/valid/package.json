{
  "name": "@owdproject/app-fixture-valid",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": ["dist"],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/app-fixture-valid/} nuxt generate playground"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.3.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2"
  }
}
